function dFe_dt = dFedt(J_FeFe_V,dx)
[nJ,ny]=size(J_Fe_V);
nx = nJ+1;
grad_J = zeros(nx);
for i = 1:nx
    if i == 1
        J_ghost = -J_FeFe_V(i);
        grad_J(i) = (J_FeFe_V(i)-J_ghost)/dx;
    elseif i == nx
        grad_J = 0.0;
    else
        grad_J = (J_FeFe_V(i)-J_FeFe_V(i-1))/dx;
    end
    dCr_dt = -grad_J;
end

end